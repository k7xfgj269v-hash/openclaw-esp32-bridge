# === Server Configuration ===

# Port the voice server listens on
SERVER_PORT=8080

# === OpenClaw Binary ===

# Absolute path to the openclaw executable
OPENCLAW_BIN=/home/ubuntu/.npm-global/bin/openclaw

# PATH injected into subprocess environment so openclaw can locate its dependencies
OPENCLAW_PATH_ENV=/home/ubuntu/.npm-global/bin:/usr/bin:/bin

# === OpenClaw Agent ===

# Agent ID used when spawning OpenClaw sub-agent sessions
OPENCLAW_AGENT_ID=esp32-voice
